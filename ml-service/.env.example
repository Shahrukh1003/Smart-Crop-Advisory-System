# =============================================================================
# Smart Crop Advisory System - ML Service Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# =============================================================================

# -----------------------------------------------------------------------------
# Service Configuration
# -----------------------------------------------------------------------------
SERVICE_HOST=0.0.0.0                    # Host to bind to
SERVICE_PORT=8000                       # Port to listen on
ENVIRONMENT=development                 # development | production | test

# -----------------------------------------------------------------------------
# Model Paths
# -----------------------------------------------------------------------------
# Paths are relative to the ml-service directory
MODEL_DIR=models                        # Directory containing model files
CROP_MODEL_PATH=models/crop_recommendation_model.pkl
PEST_MODEL_PATH=models/pest_detection_model.tflite

# -----------------------------------------------------------------------------
# Model Configuration
# -----------------------------------------------------------------------------
CROP_MODEL_VERSION=1.0.0
PEST_MODEL_VERSION=1.0.0
MIN_CONFIDENCE_THRESHOLD=0.5            # Minimum confidence for predictions
MAX_RECOMMENDATIONS=5                   # Maximum crop recommendations to return

# -----------------------------------------------------------------------------
# Pest Detection Settings
# -----------------------------------------------------------------------------
PEST_IMAGE_SIZE=224                     # Input image size for MobileNetV2
PEST_SEVERITY_THRESHOLDS=0.3,0.6        # Low/Medium/High severity thresholds

# -----------------------------------------------------------------------------
# Crop Recommendation Settings
# -----------------------------------------------------------------------------
# Soil parameter ranges for validation
SOIL_PH_MIN=4.0
SOIL_PH_MAX=9.0
SOIL_NPK_MIN=0
SOIL_NPK_MAX=500

# -----------------------------------------------------------------------------
# Fallback Configuration
# -----------------------------------------------------------------------------
FALLBACK_ENABLED=true                   # Enable rule-based fallback
FALLBACK_DISCLAIMER="Using simplified recommendations based on general guidelines."

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# -----------------------------------------------------------------------------
# Performance Settings
# -----------------------------------------------------------------------------
MAX_WORKERS=4                           # Number of worker processes
REQUEST_TIMEOUT=30                      # Request timeout in seconds
MAX_IMAGE_SIZE_MB=10                    # Maximum image upload size in MB

# -----------------------------------------------------------------------------
# CORS Configuration (for development)
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=true

# =============================================================================
# Smart Crop Advisory System - Mobile App Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# =============================================================================

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# Backend API URL - Update this to your backend server address
# For local development with Expo, use your machine's IP address
# For production, use your production API URL
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1

# API Timeout (in milliseconds)
EXPO_PUBLIC_API_TIMEOUT=30000

# -----------------------------------------------------------------------------
# Firebase Configuration (Push Notifications)
# -----------------------------------------------------------------------------
# Get these values from your Firebase project settings
# https://console.firebase.google.com/
EXPO_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
EXPO_PUBLIC_FIREBASE_APP_ID=your-app-id

# -----------------------------------------------------------------------------
# Offline Configuration
# -----------------------------------------------------------------------------
# Cache TTL values (in milliseconds)
EXPO_PUBLIC_CACHE_TTL_WEATHER=3600000           # 1 hour
EXPO_PUBLIC_CACHE_TTL_MARKET=3600000            # 1 hour
EXPO_PUBLIC_CACHE_TTL_RECOMMENDATIONS=86400000  # 24 hours

# Sync Configuration
EXPO_PUBLIC_SYNC_INTERVAL=120000                # 2 minutes
EXPO_PUBLIC_SYNC_RETRY_ATTEMPTS=3

# -----------------------------------------------------------------------------
# Voice Service Configuration
# -----------------------------------------------------------------------------
EXPO_PUBLIC_VOICE_ENABLED=true
EXPO_PUBLIC_VOICE_TIMEOUT=10000                 # 10 seconds

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
EXPO_PUBLIC_ENABLE_OFFLINE_MODE=true
EXPO_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=true
EXPO_PUBLIC_ENABLE_VOICE_COMMANDS=true
EXPO_PUBLIC_ENABLE_ANALYTICS=false

# -----------------------------------------------------------------------------
# Development Settings
# -----------------------------------------------------------------------------
# Enable debug logging in development
EXPO_PUBLIC_DEBUG_MODE=false

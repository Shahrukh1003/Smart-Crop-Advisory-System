# =============================================================================
# Smart Crop Advisory System - Backend Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# For production, ensure all secrets are properly secured and rotated regularly.
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
NODE_ENV=development                    # development | production | test
PORT=3000                               # Server port

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL via Prisma)
# -----------------------------------------------------------------------------
# Connection pooling is configured via URL parameters for optimal performance
# connection_limit: Maximum number of connections in the pool
# pool_timeout: Time to wait for a connection from the pool (seconds)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/smart_crop_advisory?schema=public&connection_limit=10&pool_timeout=10"

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
# IMPORTANT: Change these secrets in production!
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=24h                      # Access token expiry
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_REFRESH_EXPIRES_IN=30d              # Refresh token expiry

# -----------------------------------------------------------------------------
# Redis Cache Configuration
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                         # Leave empty for local dev, set for production
REDIS_URL=                              # Optional: Full Redis URL (overrides host/port/password)

# Cache TTL Settings (in seconds)
REDIS_TTL_CURRENT_WEATHER=3600          # 1 hour for current weather
REDIS_TTL_FORECAST=21600                # 6 hours for forecasts
CACHE_DEFAULT_TTL=3600                  # 1 hour default
CACHE_MARKET_TTL=3600                   # 1 hour for market prices
CACHE_RECOMMENDATIONS_TTL=86400         # 24 hours for recommendations
CACHE_SESSION_TTL=86400                 # 24 hours for sessions

# -----------------------------------------------------------------------------
# OpenWeatherMap API (Weather Service)
# -----------------------------------------------------------------------------
# Get your API key from: https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key
OPENWEATHERMAP_API_URL=https://api.openweathermap.org/data/2.5
OPENWEATHERMAP_TIMEOUT=3000             # Request timeout in ms
OPENWEATHERMAP_MAX_RETRIES=3            # Number of retry attempts
OPENWEATHERMAP_RATE_LIMIT=60            # Requests per minute

# Legacy weather config (deprecated, use OPENWEATHERMAP_* instead)
WEATHER_API_KEY=your-openweathermap-api-key
WEATHER_API_URL=https://api.openweathermap.org/data/2.5

# Weather Alert Thresholds
WEATHER_ALERT_HEAVY_RAIN_MM=15          # Heavy rain threshold in mm
WEATHER_ALERT_HEAT_WAVE_CELSIUS=40      # Heat wave threshold in °C
WEATHER_ALERT_FROST_CELSIUS=10          # Frost warning threshold in °C
WEATHER_ALERT_HIGH_WIND_KMH=30          # High wind threshold in km/h

# -----------------------------------------------------------------------------
# Market Price API (Agmarknet via data.gov.in)
# -----------------------------------------------------------------------------
# Get your API key from: https://data.gov.in/
MARKET_PRICE_API_URL=https://api.data.gov.in/resource/9ef84268-d588-465a-a308-a864a43d0070
MARKET_PRICE_API_KEY=your-data-gov-in-api-key
MARKET_PRICE_API_TIMEOUT=5000           # Request timeout in ms
MARKET_PRICE_CACHE_TTL=3600             # Cache TTL in seconds
MARKET_PRICE_CHANGE_THRESHOLD=15        # Price change alert threshold (%)
MARKET_DEFAULT_RADIUS_KM=100            # Default search radius in km
MARKET_TRANSPORT_COST_PER_KM=5          # Transportation cost per km in INR

# -----------------------------------------------------------------------------
# ML Service Configuration
# -----------------------------------------------------------------------------
ML_SERVICE_URL=http://localhost:8000
ML_SERVICE_TIMEOUT=10000                # Request timeout in ms
ML_SERVICE_FALLBACK_ENABLED=true        # Enable rule-based fallback

# -----------------------------------------------------------------------------
# Google Cloud Configuration (Voice Services)
# -----------------------------------------------------------------------------
# Set up a Google Cloud project and enable Speech-to-Text and Text-to-Speech APIs
# Download service account credentials JSON file
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=./credentials/google-cloud-key.json

# Speech-to-Text Configuration
GOOGLE_STT_LANGUAGE_MODEL=latest_long   # Model for Indic language support
GOOGLE_STT_SAMPLE_RATE=16000            # Audio sample rate in Hz
GOOGLE_STT_ENCODING=LINEAR16            # Audio encoding format

# Text-to-Speech Configuration
GOOGLE_TTS_AUDIO_ENCODING=MP3           # Output audio format
GOOGLE_TTS_SPEAKING_RATE=1.0            # Speaking rate (0.25 to 4.0)
GOOGLE_TTS_PITCH=0.0                    # Voice pitch (-20.0 to 20.0)

# Voice Service Settings
VOICE_SERVICE_TIMEOUT=10000             # Request timeout in ms
VOICE_SERVICE_FALLBACK_ENABLED=true     # Enable text fallback on voice failure
VOICE_MIN_ACCURACY=0.85                 # Minimum transcription accuracy (85%)

# Supported Languages (comma-separated)
VOICE_SUPPORTED_LANGUAGES=kn,hi,ta,te,en

# -----------------------------------------------------------------------------
# Firebase Cloud Messaging (Push Notifications)
# -----------------------------------------------------------------------------
# Set up Firebase project and download service account credentials
# https://console.firebase.google.com/
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# FCM Settings
FCM_NOTIFICATION_PRIORITY=high          # high | normal
FCM_WEATHER_ALERT_DELAY_MINUTES=5       # Max delay for weather alerts

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
THROTTLE_TTL=60000                      # Time window in ms (1 minute)
THROTTLE_LIMIT=100                      # Max requests per window per user

# -----------------------------------------------------------------------------
# File Upload Configuration
# -----------------------------------------------------------------------------
MAX_FILE_SIZE=10485760                  # Max file size in bytes (10MB)
UPLOAD_DIR=uploads                      # Upload directory
ALLOWED_FILE_TYPES=image/jpeg,image/png # Allowed MIME types

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
# Encryption key for sensitive data at rest (32 bytes for AES-256)
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:19006
CORS_METHODS=GET,POST,PUT,DELETE,PATCH

# Helmet Security Headers
HELMET_ENABLED=true

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=debug                         # debug | info | warn | error
LOG_FORMAT=json                         # json | pretty

# -----------------------------------------------------------------------------
# Performance Monitoring (Optional)
# -----------------------------------------------------------------------------
# APM_ENABLED=false
# APM_SERVICE_NAME=smart-crop-backend
# APM_SERVER_URL=http://localhost:8200

# =============================================================================
# Smart Crop Advisory System - Production Environment Template
# =============================================================================
# IMPORTANT: This is a template for production deployment.
# 1. Copy this file to .env.production
# 2. Fill in ALL values with production credentials
# 3. NEVER commit production credentials to version control
# 4. Use secrets management (AWS Secrets Manager, HashiCorp Vault, etc.)
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=3000

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# Use a managed PostgreSQL service (AWS RDS, Google Cloud SQL, etc.)
# Enable SSL for production connections
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public&connection_limit=20&pool_timeout=10&sslmode=require"

# -----------------------------------------------------------------------------
# JWT Authentication (MUST CHANGE FOR PRODUCTION)
# -----------------------------------------------------------------------------
# Generate strong secrets: openssl rand -base64 64
JWT_SECRET=GENERATE_STRONG_SECRET_HERE
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=GENERATE_DIFFERENT_STRONG_SECRET_HERE
JWT_REFRESH_EXPIRES_IN=30d

# -----------------------------------------------------------------------------
# Redis Cache (Production)
# -----------------------------------------------------------------------------
# Use a managed Redis service (AWS ElastiCache, Redis Cloud, etc.)
REDIS_HOST=your-redis-host.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD
# Or use full URL:
# REDIS_URL=rediss://:PASSWORD@HOST:6379

# Cache TTL Settings
REDIS_TTL_CURRENT_WEATHER=3600
REDIS_TTL_FORECAST=21600
CACHE_DEFAULT_TTL=3600
CACHE_MARKET_TTL=3600
CACHE_RECOMMENDATIONS_TTL=86400
CACHE_SESSION_TTL=86400

# -----------------------------------------------------------------------------
# OpenWeatherMap API
# -----------------------------------------------------------------------------
OPENWEATHERMAP_API_KEY=YOUR_PRODUCTION_API_KEY
OPENWEATHERMAP_API_URL=https://api.openweathermap.org/data/2.5
OPENWEATHERMAP_TIMEOUT=3000
OPENWEATHERMAP_MAX_RETRIES=3
OPENWEATHERMAP_RATE_LIMIT=60

# Weather Alert Thresholds
WEATHER_ALERT_HEAVY_RAIN_MM=15
WEATHER_ALERT_HEAT_WAVE_CELSIUS=40
WEATHER_ALERT_FROST_CELSIUS=10
WEATHER_ALERT_HIGH_WIND_KMH=30

# -----------------------------------------------------------------------------
# Market Price API (Agmarknet)
# -----------------------------------------------------------------------------
MARKET_PRICE_API_URL=https://api.data.gov.in/resource/9ef84268-d588-465a-a308-a864a43d0070
MARKET_PRICE_API_KEY=YOUR_DATA_GOV_IN_API_KEY
MARKET_PRICE_API_TIMEOUT=5000
MARKET_PRICE_CACHE_TTL=3600
MARKET_PRICE_CHANGE_THRESHOLD=15
MARKET_DEFAULT_RADIUS_KM=100
MARKET_TRANSPORT_COST_PER_KM=5

# -----------------------------------------------------------------------------
# ML Service
# -----------------------------------------------------------------------------
ML_SERVICE_URL=http://ml-service:8000
ML_SERVICE_TIMEOUT=10000
ML_SERVICE_FALLBACK_ENABLED=true

# -----------------------------------------------------------------------------
# Google Cloud (Voice Services)
# -----------------------------------------------------------------------------
GOOGLE_CLOUD_PROJECT_ID=YOUR_PROJECT_ID
# In production, use mounted credentials or workload identity
GOOGLE_APPLICATION_CREDENTIALS=/secrets/google-cloud-key.json

GOOGLE_STT_LANGUAGE_MODEL=latest_long
GOOGLE_STT_SAMPLE_RATE=16000
GOOGLE_STT_ENCODING=LINEAR16
GOOGLE_TTS_AUDIO_ENCODING=MP3
GOOGLE_TTS_SPEAKING_RATE=1.0
GOOGLE_TTS_PITCH=0.0
VOICE_SERVICE_TIMEOUT=10000
VOICE_SERVICE_FALLBACK_ENABLED=true
VOICE_MIN_ACCURACY=0.85
VOICE_SUPPORTED_LANGUAGES=kn,hi,ta,te,en

# -----------------------------------------------------------------------------
# Firebase Cloud Messaging
# -----------------------------------------------------------------------------
FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
# Store private key securely - use secrets management
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FCM_NOTIFICATION_PRIORITY=high
FCM_WEATHER_ALERT_DELAY_MINUTES=5

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# -----------------------------------------------------------------------------
# File Upload
# -----------------------------------------------------------------------------
MAX_FILE_SIZE=10485760
UPLOAD_DIR=/app/uploads
ALLOWED_FILE_TYPES=image/jpeg,image/png

# -----------------------------------------------------------------------------
# Security (MUST CHANGE FOR PRODUCTION)
# -----------------------------------------------------------------------------
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=GENERATE_32_BYTE_KEY_HERE

# CORS - Restrict to your production domains
CORS_ORIGINS=https://your-production-domain.com
CORS_METHODS=GET,POST,PUT,DELETE,PATCH
HELMET_ENABLED=true

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# Performance Monitoring (Optional)
# -----------------------------------------------------------------------------
# APM_ENABLED=true
# APM_SERVICE_NAME=smart-crop-backend
# APM_SERVER_URL=https://your-apm-server.com

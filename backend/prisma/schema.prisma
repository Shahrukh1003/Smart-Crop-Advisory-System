generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Language {
  kn
  hi
  ta
  te
  en
}

enum UserRole {
  farmer
  extension_officer
  admin
}

enum IrrigationType {
  rainfed
  drip
  sprinkler
  flood
}

enum ActivityType {
  sowing
  irrigation
  fertilization
  pesticide
  weeding
  harvest
}

enum Season {
  kharif
  rabi
  zaid
}

enum Severity {
  low
  medium
  high
}

enum TreatmentType {
  organic
  chemical
}

enum AlertType {
  heavy_rain
  heat_wave
  frost
  storm
}

enum PriceTrend {
  rising
  falling
  stable
}

enum SyncStatus {
  pending
  syncing
  completed
  failed
}

enum DeliveryStatus {
  sent
  delivered
  read
}

enum Priority {
  low
  medium
  high
}

model User {
  id           String    @id @default(uuid())
  phoneNumber  String    @unique @map("phone_number")
  name         String
  language     Language
  latitude     Decimal?  @db.Decimal(10, 8)
  longitude    Decimal?  @db.Decimal(11, 8)
  district     String?
  state        String?
  passwordHash String    @map("password_hash")
  role         UserRole  @default(farmer)
  createdAt    DateTime  @default(now()) @map("created_at")
  lastSyncAt   DateTime? @map("last_sync_at")

  landParcels      LandParcel[]
  cropHistories    CropHistory[]
  recommendations  CropRecommendation[]
  pestDetections   PestDetection[]
  broadcasts       Broadcast[]          @relation("BroadcastSender")
  deliveries       BroadcastDelivery[]
  analyticsEvents  AnalyticsEvent[]
  feedback         Feedback[]
  syncQueue        SyncQueueItem[]
  deviceTokens     DeviceToken[]
  notificationLogs NotificationLog[]

  // Indexes for frequent queries
  @@index([role])
  @@index([district])
  @@index([state])
  @@index([language])
  @@index([district, state])
  @@index([latitude, longitude])
  @@index([createdAt])
  @@index([role, district, state]) // Composite for broadcast targeting
  @@map("users")
}

model LandParcel {
  id             String          @id @default(uuid())
  userId         String          @map("user_id")
  area           Decimal         @db.Decimal(10, 2)
  soilType       String?         @map("soil_type")
  irrigationType IrrigationType? @map("irrigation_type")
  createdAt      DateTime        @default(now()) @map("created_at")

  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  soilTestResults SoilTestResult[]
  cropHistories   CropHistory[]
  recommendations CropRecommendation[]

  @@index([userId])
  @@index([soilType])
  @@map("land_parcels")
}

model SoilTestResult {
  id            String   @id @default(uuid())
  parcelId      String   @map("parcel_id")
  nitrogen      Decimal? @db.Decimal(10, 2)
  phosphorus    Decimal? @db.Decimal(10, 2)
  potassium     Decimal? @db.Decimal(10, 2)
  ph            Decimal? @db.Decimal(4, 2)
  organicMatter Decimal? @map("organic_matter") @db.Decimal(5, 2)
  testDate      DateTime @map("test_date")
  createdAt     DateTime @default(now()) @map("created_at")

  parcel LandParcel @relation(fields: [parcelId], references: [id], onDelete: Cascade)

  @@index([parcelId])
  @@index([testDate])
  @@map("soil_test_results")
}

model CropHistory {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  parcelId    String    @map("parcel_id")
  cropName    String    @map("crop_name")
  variety     String?
  sowingDate  DateTime  @map("sowing_date")
  harvestDate DateTime? @map("harvest_date")
  yield       Decimal?  @db.Decimal(10, 2)
  revenue     Decimal?  @db.Decimal(12, 2)
  createdAt   DateTime  @default(now()) @map("created_at")

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  parcel     LandParcel        @relation(fields: [parcelId], references: [id], onDelete: Cascade)
  inputCosts InputCost?
  activities FarmingActivity[]

  @@index([userId])
  @@index([parcelId])
  @@index([cropName])
  @@index([sowingDate])
  @@index([userId, cropName])
  @@map("crop_history")
}

model InputCost {
  id          String  @id @default(uuid())
  historyId   String  @unique @map("history_id")
  seeds       Decimal @default(0) @db.Decimal(10, 2)
  fertilizers Decimal @default(0) @db.Decimal(10, 2)
  pesticides  Decimal @default(0) @db.Decimal(10, 2)
  labor       Decimal @default(0) @db.Decimal(10, 2)
  irrigation  Decimal @default(0) @db.Decimal(10, 2)

  history CropHistory @relation(fields: [historyId], references: [id], onDelete: Cascade)

  @@map("input_costs")
}

model FarmingActivity {
  id           String       @id @default(uuid())
  historyId    String       @map("history_id")
  activityType ActivityType @map("activity_type")
  activityDate DateTime     @map("activity_date")
  description  String?
  cost         Decimal?     @db.Decimal(10, 2)
  createdAt    DateTime     @default(now()) @map("created_at")

  history CropHistory @relation(fields: [historyId], references: [id], onDelete: Cascade)

  @@index([historyId])
  @@index([activityType])
  @@index([activityDate])
  @@map("farming_activities")
}

model CropRecommendation {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  parcelId    String   @map("parcel_id")
  season      Season?
  generatedAt DateTime @default(now()) @map("generated_at")

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  parcel           LandParcel        @relation(fields: [parcelId], references: [id], onDelete: Cascade)
  recommendedCrops RecommendedCrop[]

  // Indexes for recommendation queries
  @@index([userId])
  @@index([parcelId])
  @@index([generatedAt])
  @@index([userId, generatedAt]) // Composite for user's recent recommendations
  @@map("crop_recommendations")
}

model RecommendedCrop {
  id                 String   @id @default(uuid())
  recommendationId   String   @map("recommendation_id")
  cropName           String   @map("crop_name")
  variety            String?
  suitabilityScore   Int?     @map("suitability_score")
  expectedYield      Decimal? @map("expected_yield") @db.Decimal(10, 2)
  estimatedInputCost Decimal? @map("estimated_input_cost") @db.Decimal(12, 2)
  estimatedRevenue   Decimal? @map("estimated_revenue") @db.Decimal(12, 2)
  reasoning          String[]
  risks              String[]

  recommendation CropRecommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)

  // Indexes for recommended crop queries
  @@index([recommendationId])
  @@index([cropName])
  @@index([suitabilityScore])
  @@map("recommended_crops")
}

model PestDetection {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  imageUrl   String   @map("image_url")
  detectedAt DateTime @default(now()) @map("detected_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  detectedPests DetectedPest[]

  // Indexes for pest detection queries
  @@index([userId])
  @@index([detectedAt])
  @@index([userId, detectedAt]) // Composite for user's detection history
  @@map("pest_detections")
}

model DetectedPest {
  id            String    @id @default(uuid())
  detectionId   String    @map("detection_id")
  pestOrDisease String    @map("pest_or_disease")
  confidence    Decimal?  @db.Decimal(3, 2)
  severity      Severity?
  affectedCrop  String?   @map("affected_crop")

  detection  PestDetection @relation(fields: [detectionId], references: [id], onDelete: Cascade)
  treatments Treatment[]

  // Indexes for detected pest queries
  @@index([detectionId])
  @@index([pestOrDisease])
  @@index([severity])
  @@map("detected_pests")
}

model Treatment {
  id                String        @id @default(uuid())
  detectedPestId    String        @map("detected_pest_id")
  type              TreatmentType
  name              String
  dosage            String?
  applicationMethod String?       @map("application_method")
  cost              Decimal?      @db.Decimal(10, 2)
  effectiveness     Int?

  detectedPest DetectedPest @relation(fields: [detectedPestId], references: [id], onDelete: Cascade)

  // Indexes for treatment queries
  @@index([detectedPestId])
  @@index([type])
  @@map("treatments")
}

model WeatherData {
  id          String   @id @default(uuid())
  latitude    Decimal  @db.Decimal(10, 8)
  longitude   Decimal  @db.Decimal(11, 8)
  temperature Decimal? @db.Decimal(5, 2)
  humidity    Decimal? @db.Decimal(5, 2)
  rainfall    Decimal? @db.Decimal(6, 2)
  windSpeed   Decimal? @map("wind_speed") @db.Decimal(5, 2)
  recordedAt  DateTime @default(now()) @map("recorded_at")

  forecasts WeatherForecast[]

  // Indexes for weather queries
  @@index([latitude, longitude]) // Location-based queries
  @@index([recordedAt])
  @@index([latitude, longitude, recordedAt]) // Composite for location + time queries
  @@map("weather_data")
}

model WeatherForecast {
  id           String   @id @default(uuid())
  weatherId    String   @map("weather_id")
  forecastDate DateTime @map("forecast_date")
  minTemp      Decimal? @map("min_temp") @db.Decimal(5, 2)
  maxTemp      Decimal? @map("max_temp") @db.Decimal(5, 2)
  rainfall     Decimal? @db.Decimal(6, 2)
  humidity     Decimal? @db.Decimal(5, 2)

  weather WeatherData @relation(fields: [weatherId], references: [id], onDelete: Cascade)

  // Indexes for forecast queries
  @@index([weatherId])
  @@index([forecastDate])
  @@map("weather_forecasts")
}

model MarketPrice {
  id          String      @id @default(uuid())
  commodity   String
  variety     String?
  marketName  String      @map("market_name")
  district    String
  minPrice    Decimal?    @map("min_price") @db.Decimal(10, 2)
  maxPrice    Decimal?    @map("max_price") @db.Decimal(10, 2)
  modalPrice  Decimal?    @map("modal_price") @db.Decimal(10, 2)
  unit        String?
  priceDate   DateTime    @map("price_date")
  trend       PriceTrend?
  priceChange Decimal?    @map("price_change") @db.Decimal(5, 2)
  createdAt   DateTime    @default(now()) @map("created_at")

  // Indexes for market price queries
  @@index([commodity])
  @@index([district])
  @@index([priceDate])
  @@index([commodity, priceDate]) // Composite for price history queries
  @@index([commodity, district, priceDate]) // Composite for location-based price queries
  @@map("market_prices")
}

model Broadcast {
  id           String    @id @default(uuid())
  senderId     String    @map("sender_id")
  title        String
  content      String
  audioUrl     String?   @map("audio_url")
  imageUrl     String?   @map("image_url")
  language     Language
  targetRegion Json      @map("target_region")
  priority     Priority?
  createdAt    DateTime  @default(now()) @map("created_at")

  sender     User                @relation("BroadcastSender", fields: [senderId], references: [id], onDelete: Cascade)
  deliveries BroadcastDelivery[]

  // Indexes for broadcast queries
  @@index([senderId])
  @@index([createdAt])
  @@index([language])
  @@index([priority])
  @@map("broadcasts")
}

model BroadcastDelivery {
  id             String         @id @default(uuid())
  broadcastId    String         @map("broadcast_id")
  recipientId    String         @map("recipient_id")
  deliveryStatus DeliveryStatus @map("delivery_status")
  deliveredAt    DateTime?      @map("delivered_at")
  readAt         DateTime?      @map("read_at")

  broadcast Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  recipient User      @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  // Indexes for delivery queries
  @@index([broadcastId])
  @@index([recipientId])
  @@index([deliveryStatus])
  @@index([broadcastId, recipientId]) // Composite for unique delivery lookup
  @@map("broadcast_deliveries")
}

model AnalyticsEvent {
  id             String   @id @default(uuid())
  userId         String?  @map("user_id")
  feature        String
  sessionId      String   @map("session_id")
  eventTimestamp DateTime @default(now()) @map("event_timestamp")
  metadata       Json?    @map("metadata")
  duration       Int?     @map("duration_ms")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Indexes for efficient time-series queries
  @@index([eventTimestamp])
  @@index([feature, eventTimestamp])
  @@index([userId, eventTimestamp])
  @@index([sessionId])
  @@map("analytics_events")
}

model Feedback {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  feature   String
  rating    Int?
  comment   String?
  context   Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Indexes for feedback queries
  @@index([userId])
  @@index([feature])
  @@index([createdAt])
  @@index([userId, feature]) // Composite for user's feature feedback
  @@index([feature, createdAt]) // Composite for feature feedback over time
  @@map("feedback")
}

model SyncQueueItem {
  id         String     @id @default(uuid())
  userId     String     @map("user_id")
  operation  String
  entityType String     @map("entity_type")
  entityData Json       @map("entity_data")
  syncStatus SyncStatus @map("sync_status")
  retryCount Int        @default(0) @map("retry_count")
  createdAt  DateTime   @default(now()) @map("created_at")
  syncedAt   DateTime?  @map("synced_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Indexes for sync queue queries
  @@index([userId])
  @@index([syncStatus])
  @@index([createdAt])
  @@index([userId, syncStatus]) // Composite for user's pending items
  @@index([syncStatus, createdAt]) // Composite for processing queue
  @@map("sync_queue")
}

enum DevicePlatform {
  android
  ios
}

enum NotificationType {
  weather_alert
  market_alert
  broadcast
  reminder
}

enum NotificationStatus {
  pending
  sent
  delivered
  failed
  read
}

model DeviceToken {
  id         String         @id @default(uuid())
  userId     String         @map("user_id")
  token      String         @unique
  platform   DevicePlatform
  isActive   Boolean        @default(true) @map("is_active")
  createdAt  DateTime       @default(now()) @map("created_at")
  lastUsedAt DateTime       @default(now()) @map("last_used_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("device_tokens")
}

model NotificationLog {
  id           String             @id @default(uuid())
  userId       String             @map("user_id")
  type         NotificationType
  title        String
  body         String
  data         Json?
  status       NotificationStatus @default(pending)
  sentAt       DateTime           @default(now()) @map("sent_at")
  deliveredAt  DateTime?          @map("delivered_at")
  readAt       DateTime?          @map("read_at")
  fcmMessageId String?            @map("fcm_message_id")
  errorMessage String?            @map("error_message")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Indexes for notification queries
  @@index([userId])
  @@index([status])
  @@index([sentAt])
  @@index([type])
  @@index([userId, status]) // Composite for user's unread notifications
  @@index([userId, sentAt]) // Composite for user's notification history
  @@map("notification_logs")
}
